# Dira environment — copy to .env and fill secrets. Never commit .env.

# live | seeded  — demo always runs seeded
DATA_MODE=seeded

DATABASE_URL=postgresql://dira:dira@localhost:5432/dira

API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000

# LLM (optional in seeded mode — use canned adapters)
ANTHROPIC_API_KEY=

# ACLED (live mode only)
ACLED_EMAIL=
ACLED_PASSWORD=

# Africa's Talking (live voice/SMS) — also accept AT_* aliases
AT_USERNAME=
AT_API_KEY=
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_SHORTCODE=

# TTS provider (live); seeded uses data/seeded/audio/
TTS_PROVIDER=
TTS_API_KEY=

# Embeddings: local BGE-M3 (1024 dims); seeded uses zeros/precomputed
EMBEDDING_MODEL=BAAI/bge-m3

# Dispatch / situation hysteresis
ZOMBIE_TIMEOUT_MINUTES=10
DISPATCH_POLL_SECONDS=30
MAX_DISPATCH_ATTEMPTS=5
RESOLVE_AFTER_CYCLES_BELOW_THRESHOLD=3

# MockDispatcher simulated ack delay (seconds) in seeded mode
MOCK_ACK_DELAY_SECONDS=2
