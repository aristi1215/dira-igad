# Dira environment — copy to .env and fill secrets. Never commit .env.

# live | seeded  — demo always runs seeded
DATA_MODE=seeded

# Host port 55432 avoids clashing with local Postgres on 5432–5434 (see infra/docker-compose.yml).
DATABASE_URL=postgresql://dira:dira@localhost:55432/dira

API_HOST=0.0.0.0
API_PORT=8000
PUBLIC_BASE_URL=http://localhost:8000

# LLM (optional in seeded mode — use canned adapters)
# Preferred language model (deviation D-010: OpenAI replaces Anthropic)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=

# ACLED (live mode only)
ACLED_EMAIL=
ACLED_PASSWORD=

# Information layer — live connectors (DATA_MODE=live only; all optional,
# each degrades to the seeded snapshot when unset or unreachable)
# HDX HAPI app identifier (free, self-service): https://hapi.humdata.org/docs
HDX_APP_IDENTIFIER=
# ReliefWeb registered appname: https://apidoc.reliefweb.int/parameters#appname
RELIEFWEB_APPNAME=
# UNHCR population API needs no key.

# Africa's Talking (live voice/SMS) — also accept AT_* aliases
# DISPATCH_MODE=at switches the dispatch daemon from MockDispatcher to the
# Africa's Talking voice API (sandbox base URL is used when AT_USERNAME=sandbox).
DISPATCH_MODE=mock
AT_USERNAME=
AT_API_KEY=
AT_VOICE_BASE_URL=
AFRICAS_TALKING_USERNAME=
AFRICAS_TALKING_API_KEY=
AFRICAS_TALKING_SHORTCODE=

# TTS provider (live); seeded uses data/seeded/audio/
TTS_PROVIDER=
TTS_API_KEY=

# Embeddings: local BGE-M3 (1024 dims); seeded uses zeros/precomputed
EMBEDDING_MODEL=BAAI/bge-m3

# Dispatch / situation hysteresis
ZOMBIE_TIMEOUT_MINUTES=10
DISPATCH_POLL_SECONDS=30
MAX_DISPATCH_ATTEMPTS=5
RESOLVE_AFTER_CYCLES_BELOW_THRESHOLD=3

# MockDispatcher simulated ack delay (seconds) in seeded mode
MOCK_ACK_DELAY_SECONDS=2
