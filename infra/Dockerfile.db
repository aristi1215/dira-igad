# PostGIS 3.4 + pgvector on PostgreSQL 16. The schema needs BOTH extensions (ADR 12), and no
# single official image ships both, so we add pgvector to the PostGIS image.
FROM postgis/postgis:16-3.4
RUN apt-get update \
    && apt-get install -y --no-install-recommends postgresql-16-pgvector \
    && rm -rf /var/lib/apt/lists/*
